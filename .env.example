# ─────────────────────────────────────────────────────────────
#  Moodify — environment. Copy to `.env.local` and fill what you have.
#  Nothing here is required to RUN the MVP (it falls back to a real
#  local Postgres + local emotion model). Fill these to go fully live.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_URL=http://127.0.0.1:3000
# Sign session cookies. Use a long random string in real deployments.
SESSION_SECRET=dev-only-change-me-to-a-long-random-secret

# ── Local database (PGlite) ──────────────────────────────────
# A real Postgres (+pgvector) embedded in the app. Zero setup.
PGLITE_DATA_DIR=./.pglite

# ── Spotify  (optional now — required to ingest YOUR library) ─
# 1. https://developer.spotify.com/dashboard  →  Create app
# 2. Add Redirect URI exactly:  http://127.0.0.1:3000/api/spotify/callback
# 3. Copy the Client ID + Secret below.  (Open the app at 127.0.0.1, not localhost.)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

# ── AI  (optional — upgrades the emotion engine from local→LLM) ─
# Without a key, a deterministic local lexicon model is used.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Supabase  (optional — only for the production port) ──────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
